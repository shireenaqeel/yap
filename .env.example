# Copy to .env and fill in.

# Groq AI key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase Postgres connection string (Project Settings -> Database ->
# Connection string -> "Session pooler" / URI). Looks like:
# postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=your_supabase_connection_string_here

# Optional overrides
GROQ_MODEL=llama-3.1-8b-instant
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
